generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String?
  passwordHash String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  WorkspaceMember[]
  assets       Asset[]
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  pages     Page[]
  templates Template[]
  vaultFiles VaultFile[]
  knowledgeEdges KnowledgeEdge[]
  tags      Tag[]
  vaultFolders VaultFolder[]
  nodeTypes NodeType[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  role        Role      @default(OWNER)
  createdAt   DateTime  @default(now())
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Page {
  id            String         @id @default(cuid())
  title         String         @default("Untitled")
  icon          String         @default("FileText")
  content       Json
  plainText     String         @default("")
  position      Int            @default(0)
  isFavorite    Boolean        @default(false)
  archivedAt    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspaceId   String
  nodeTypeId    String?
  parentId      String?
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nodeType      NodeType?      @relation(fields: [nodeTypeId], references: [id], onDelete: SetNull)
  parent        Page?          @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      Page[]         @relation("PageTree")
  outgoingLinks PageRelation[] @relation("SourcePage")
  incomingLinks PageRelation[] @relation("TargetPage")
  assets        Asset[]
  tags          PageTag[]

  @@index([workspaceId, parentId, position])
  @@index([workspaceId, nodeTypeId])
  @@index([workspaceId, archivedAt])
  @@index([workspaceId, deletedAt])
  @@index([workspaceId, plainText])
}

model PageRelation {
  id        String       @id @default(cuid())
  type      RelationType @default(LINK)
  createdAt DateTime     @default(now())
  sourceId  String
  targetId  String
  source    Page         @relation("SourcePage", fields: [sourceId], references: [id], onDelete: Cascade)
  target    Page         @relation("TargetPage", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
}

model VaultFile {
  id          String    @id @default(cuid())
  title       String
  fileName    String
  content     String    @default("")
  plainText   String    @default("")
  icon        String    @default("FileText")
  color       String    @default("cyan")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspaceId String
  folderId    String?
  nodeTypeId  String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder      VaultFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  nodeType    NodeType? @relation(fields: [nodeTypeId], references: [id], onDelete: SetNull)
  tags        VaultFileTag[]

  @@unique([workspaceId, fileName])
  @@index([workspaceId, title])
  @@index([workspaceId, folderId])
  @@index([workspaceId, nodeTypeId])
}

model VaultFolder {
  id          String      @id @default(cuid())
  name        String
  slug        String
  color       String      @default("cyan")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  files       VaultFile[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, name])
}

model Tag {
  id          String         @id @default(cuid())
  name        String
  slug        String
  color       String         @default("violet")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages       PageTag[]
  vaultFiles  VaultFileTag[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, name])
}

model PageTag {
  id     String @id @default(cuid())
  pageId String
  tagId  String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([pageId, tagId])
  @@index([tagId])
}

model VaultFileTag {
  id          String    @id @default(cuid())
  vaultFileId String
  tagId       String
  vaultFile   VaultFile @relation(fields: [vaultFileId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([vaultFileId, tagId])
  @@index([tagId])
}

model NodeType {
  id          String      @id @default(cuid())
  name        String
  slug        String
  icon        String      @default("FileText")
  color       String      @default("violet")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages       Page[]
  vaultFiles  VaultFile[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, name])
}

model KnowledgeEdge {
  id          String            @id @default(cuid())
  type        KnowledgeEdgeType @default(WIKI_LINK)
  sourceType  KnowledgeNodeType
  sourceId    String
  targetType  KnowledgeNodeType
  targetId    String
  createdAt   DateTime          @default(now())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sourceType, sourceId, targetType, targetId, type])
  @@index([workspaceId, sourceType, sourceId])
  @@index([workspaceId, targetType, targetId])
}

model Template {
  id          String    @id @default(cuid())
  name        String
  description String?
  content     Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String    @id @default(cuid())
  fileName    String
  mimeType    String
  size        Int
  url         String
  storageProvider String @default("local")
  storageKey      String?
  createdAt   DateTime  @default(now())
  userId      String
  pageId      String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  page        Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
}

enum Role {
  OWNER
  MEMBER
}

enum RelationType {
  LINK
  MENTION
}

enum KnowledgeNodeType {
  PAGE
  VAULT_FILE
}

enum KnowledgeEdgeType {
  WIKI_LINK
  MANUAL
}
